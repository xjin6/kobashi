{
  "name": "codex-copilot-bridge",
  "version": "1.1.0",
  "description": "Route OpenAI Codex through your GitHub Copilot subscription",
  "main": "index.js",
  "bin": "index.js",
  "scripts": {
    "start": "node index.js",
    "build:mac": "bash scripts/build-mac-app.sh",
    "build:win": "pkg . --targets node20-win-x64 --output dist/codex-copilot-bridge.exe"
  },
  "pkg": {
    "assets": [
      "assets/**/*"
    ]
  }
}
